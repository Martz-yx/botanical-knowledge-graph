# ==============================================================================
# SproutGraph (.env) - Environment Configuration Template
# Rename this file to .env and fill in your actual credentials.
# DO NOT commit the renamed .env to version control.
# ==============================================================================

# --- LOCAL DOCKER CONNECTION ---
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=sproutgraphdevpassword

# --- NEO4J AURA CLOUD CONNECTION ---
NEO4J_URI=neo4j+s://<your-aura-db-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-aura-generated-password>

# --- OPTIONAL CLOUD DEPLOYMENT API KEYS (For Aura API automation) ---
AURA_CLIENT_ID=<your-aura-client-id>
AURA_CLIENT_SECRET=<your-aura-client-secret>
